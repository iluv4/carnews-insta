generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Core User ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  templates     Template[]
  generatedCards GeneratedCard[]
  brands        Brand[]
  references    Reference[]
  projects      Project[]
  createdAt     DateTime  @default(now())
}

// ── Brand (고객사/브랜드 프로필) ───────────────────────────────────────────────

model Brand {
  id             String   @id @default(cuid())
  userId         String
  name           String
  businessType   String?
  logoUrl        String?  @db.Text
  primaryColor   String?
  secondaryColor String?
  tone           String?
  defaultCta     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

// ── Reference (인스타 레퍼런스 원본) ──────────────────────────────────────────

model Reference {
  id           String   @id @default(cuid())
  userId       String?
  sourceType   String   // "instagram_url" | "upload" | "saved_ref"
  sourceUrl    String?
  imageHash    String?  // sha256 for deduplication
  status       String   @default("fetched") // fetched | analyzed | failed
  imagesJson   Json     // ReferenceImage[]
  metadataJson Json?
  createdAt    DateTime @default(now())

  user      User?            @relation(fields: [userId], references: [id])
  analyses  LayoutAnalysis[]
  templates Template[]
}

// ── LayoutAnalysis (GPT Vision 구조화 분석 결과) ──────────────────────────────

model LayoutAnalysis {
  id              String   @id @default(cuid())
  referenceId     String
  rawAnalysisJson Json     // LayoutAnalysisResult (structured JSON)
  designDnaJson   Json     // GlobalStyle extracted
  slideMapJson    Json     // SlidePattern[]
  createdAt       DateTime @default(now())

  reference Reference  @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  templates Template[]
}

// ── Template (재사용 가능한 디자인 자산) ──────────────────────────────────────

model Template {
  id           String   @id @default(cuid())
  userId       String?
  referenceId  String?
  analysisId   String?
  name         String
  category     String?  // cafe | beauty | studio | education | promo | etc
  tags         Json?    // string[]
  content      String   @db.Text  // legacy JSONL (backward compat)
  templateJson Json?    // TemplateJSON (structured, new)
  previewUrl   String?  @db.Text
  isPublic     Boolean  @default(false)
  version      Int      @default(1)
  source       String?  // source instagram URL for display
  thumbnail    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User?           @relation(fields: [userId], references: [id])
  reference Reference?     @relation(fields: [referenceId], references: [id])
  analysis LayoutAnalysis? @relation(fields: [analysisId], references: [id])
  projects Project[]
}

// ── Project (카드뉴스 생성 프로젝트) ──────────────────────────────────────────

model Project {
  id         String   @id @default(cuid())
  userId     String?
  brandId    String?
  templateId String?
  title      String
  status     String   @default("draft") // draft | planning | generating | done | failed
  inputJson  Json     // GenerationInput (topic, businessType, goal, etc.)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User?      @relation(fields: [userId], references: [id])
  brand    Brand?     @relation(fields: [brandId], references: [id])
  template Template?  @relation(fields: [templateId], references: [id])
  slides   ProjectSlide[]
}

// ── ProjectSlide (슬라이드별 결과) ────────────────────────────────────────────

model ProjectSlide {
  id             String   @id @default(cuid())
  projectId      String
  slideNo        Int
  role           String   // cover | intro | problem | solution | tip | offer | cta
  contentJson    Json     // generated text content
  editableJson   Json?    // CanvasEditor layer JSON
  generatedBgUrl String?  @db.Text
  finalImageUrl  String?  @db.Text
  status         String   @default("pending") // pending | generating | done | failed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── Legacy models (backward compat) ───────────────────────────────────────────

model GeneratedCard {
  id        String   @id @default(cuid())
  userId    String?
  imageUrl  String   @db.Text
  theme     String?
  jsonlData String?  @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model AnalysisCache {
  id           String   @id @default(cuid())
  shortcode    String   @unique
  instagramUrl String
  jsonlData    String   @db.Text
  structuredJson Json?  // new: LayoutAnalysisResult
  imageUrl     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
